# MutiSaaSApp Docker Environment Configuration
# Copy this file to .env and update with your actual values

# SQL Server Configuration
MSSQL_SA_PASSWORD=YourPassword123!
MSSQL_PID=Developer

# Redis Configuration (default: redis:6379)
REDIS_CONNECTION_STRING=redis:6379

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# JWT Configuration
JWT_SECRET=your-very-long-secret-key-min-32-chars-change-in-production-12345
JWT_EXPIRY_MINUTES=60

# Logging Configuration
SERILOG_MINIMUM_LEVEL=Information
LOG_PATH=/app/logs

# Connection Strings
# For Docker: Server=sqlserver;...
# For Local: Server=.;...
DB_CONNECTION_STRING=Server=sqlserver;Database=MutiSaaSAppDb;User Id=sa;Password=YourPassword123!;Encrypt=false;TrustServerCertificate=true;
